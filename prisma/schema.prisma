generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?     @db.Text
  ingredients String?     @db.Text
  howToUse    String?     @db.Text
  routine     String?     @db.Text
  cautions    String?     @db.Text
  price       Float
  salePrice   Float?
  images      String[]
  stock       Int         @default(0)
  isActive    Boolean     @default(true)
  categories  Category[]  @relation("ProductCategories")
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([slug])
  @@index([isActive])
  @@index([price])
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?   @db.Text
  tagline     String?
  image       String?
  sortOrder   Int       @default(0)
  products    Product[] @relation("ProductCategories")

  @@index([slug])
}

model SkinConcern {
  id        String @id @default(cuid())
  name      String
  slug      String @unique
  icon      String?
  sortOrder Int    @default(0)
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  customerId      String?
  customer        Customer?   @relation(fields: [customerId], references: [id])
  guestEmail      String?
  items           OrderItem[]
  subtotal        Float
  shippingCost    Float       @default(0)
  total           Float
  status          OrderStatus @default(PENDING)
  paymentId       String?
  paypalOrderId   String?
  shippingAddress Json
  notes           String?     @db.Text
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String
  image     String
  price     Float
  quantity  Int

  @@index([orderId])
}

model Customer {
  id           String   @id @default(cuid())
  supabaseUid  String?  @unique
  name         String
  email        String   @unique
  phone        String?
  addresses    Json[]
  orders       Order[]
  createdAt    DateTime @default(now())

  @@index([email])
  @@index([supabaseUid])
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String   @db.Text
  reviewed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([reviewed])
  @@index([createdAt])
}

model Review {
  id           String   @id @default(cuid())
  customerName String
  rating       Int
  body         String   @db.Text
  productName  String?
  approved     Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([approved])
}

model Blog {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?   @db.Text
  body        String    @db.Text
  coverImage  String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([slug])
  @@index([published])
}

model Content {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  type      String   @default("text")
  updatedAt DateTime @updatedAt
}

model Admin {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String
  role         String @default("editor")
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}
